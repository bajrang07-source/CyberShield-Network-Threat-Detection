<%- include('../partials/header') %>

<section class="error-section">
  <div class="container text-center">
    <div class="error-content">
      <div class="error-number">404</div>
      <div class="error-icon"><i class="fas fa-dumbbell"></i></div>
      <h1 class="error-title">Looks Like You Missed a Rep!</h1>
      <p class="error-sub">
        The page you're looking for doesn't exist or has been moved.<br />
        Let's get you back on track.
      </p>
      <div class="error-buttons">
        <a href="/" class="btn btn-primary-custom btn-lg me-3" id="error-home-btn">
          <i class="fas fa-home me-2"></i>Back to Home
        </a>
        <a href="/contact" class="btn btn-outline-primary-custom btn-lg" id="error-contact-btn">
          <i class="fas fa-headset me-2"></i>Contact Support
        </a>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/layout_end') %>
