<%- include('../partials/header') %>

<!-- Page Hero -->
<section class="page-hero">
  <div class="page-hero-overlay"></div>
  <div class="container text-center page-hero-content">
    <h1 class="page-hero-title">About <span class="text-gradient">FitZone</span></h1>
    <p class="page-hero-sub">Our story, our mission, and our passion for fitness</p>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb justify-content-center">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item active">About Us</li>
      </ol>
    </nav>
  </div>
</section>

<!-- Mission -->
<section class="py-5">
  <div class="container py-4">
    <div class="row align-items-center g-5">
      <div class="col-lg-6">
        <div class="about-image-wrapper">
          <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=600&h=500&fit=crop&q=80" alt="FitZone Gym" class="about-img" />
          <div class="about-badge">
            <span class="badge-number">10+</span>
            <span class="badge-label">Years of Excellence</span>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="section-tag">Our Story</div>
        <h2 class="section-title">Built by Athletes, For Everyone</h2>
        <p class="section-text">
          FitZone was founded in 2014 by a group of passionate fitness enthusiasts who believed that premium gym facilities shouldn't be limited to the elite. We built a space where everyone — from beginners to professional athletes — can thrive.
        </p>
        <p class="section-text">
          Over the past decade, we've grown from a single studio to a full-scale fitness center with over 5,000 active members, 50+ certified trainers, and 100+ classes per week.
        </p>
        <div class="row g-3 mt-3">
          <div class="col-6">
            <div class="stat-box">
              <span class="stat-box-number">5000+</span>
              <span class="stat-box-label">Active Members</span>
            </div>
          </div>
          <div class="col-6">
            <div class="stat-box">
              <span class="stat-box-number">50+</span>
              <span class="stat-box-label">Expert Trainers</span>
            </div>
          </div>
          <div class="col-6">
            <div class="stat-box">
              <span class="stat-box-number">100+</span>
              <span class="stat-box-label">Classes/Week</span>
            </div>
          </div>
          <div class="col-6">
            <div class="stat-box">
              <span class="stat-box-number">10+</span>
              <span class="stat-box-label">Years Running</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Values -->
<section class="py-5 bg-dark-section">
  <div class="container py-4">
    <div class="text-center mb-5">
      <div class="section-tag">Our Values</div>
      <h2 class="section-title text-light">What Drives Us</h2>
    </div>
    <div class="row g-4">
      <div class="col-lg-3 col-md-6">
        <div class="value-card text-center">
          <div class="value-icon"><i class="fas fa-heart"></i></div>
          <h4>Passion</h4>
          <p>We are deeply passionate about fitness and helping every member achieve their personal best.</p>
        </div>
      </div>
      <div class="col-lg-3 col-md-6">
        <div class="value-card text-center">
          <div class="value-icon"><i class="fas fa-users"></i></div>
          <h4>Community</h4>
          <p>FitZone is more than a gym — it's a family. We celebrate every victory together.</p>
        </div>
      </div>
      <div class="col-lg-3 col-md-6">
        <div class="value-card text-center">
          <div class="value-icon"><i class="fas fa-trophy"></i></div>
          <h4>Excellence</h4>
          <p>From equipment to coaching, we never settle for anything less than the best.</p>
        </div>
      </div>
      <div class="col-lg-3 col-md-6">
        <div class="value-card text-center">
          <div class="value-icon"><i class="fas fa-infinity"></i></div>
          <h4>Growth</h4>
          <p>We believe in continuous improvement — for our members and for ourselves.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Facilities -->
<section class="py-5">
  <div class="container py-4">
    <div class="text-center mb-5">
      <div class="section-tag">Facilities</div>
      <h2 class="section-title">World-Class Infrastructure</h2>
    </div>
    <div class="row g-4">
      <div class="col-md-4">
        <div class="facility-card">
          <i class="fas fa-running"></i>
          <h5>Cardio Zone</h5>
          <p>50+ treadmills, ellipticals, bikes, and rowing machines</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="facility-card">
          <i class="fas fa-dumbbell"></i>
          <h5>Strength Area</h5>
          <p>Free weights, cable machines, and power racks for all levels</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="facility-card">
          <i class="fas fa-spa"></i>
          <h5>Recovery Suite</h5>
          <p>Sauna, steam room, ice bath, and massage therapy</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="facility-card">
          <i class="fas fa-swimming-pool"></i>
          <h5>Swimming Pool</h5>
          <p>Olympic-size heated pool with lap lanes and aqua classes</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="facility-card">
          <i class="fas fa-om"></i>
          <h5>Yoga Studio</h5>
          <p>Dedicated studio with expert yoga and meditation sessions</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="facility-card">
          <i class="fas fa-apple-alt"></i>
          <h5>Nutrition Bar</h5>
          <p>Healthy smoothies, protein shakes, and post-workout snacks</p>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/layout_end') %>
